# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# app data
/data/
/uploads/*
!/uploads/.gitkeep

# Brand profiles — IP-bearing assets (PDFs, style references) live on the
# Fly volume, not in the public repo. The dir is kept (with .gitkeep) so the
# Dockerfile build context still works for fresh clones.
/brands/*
!/brands/.gitkeep

# Local Docker test volume
/local-vol/

# typescript
*.tsbuildinfo
next-env.d.ts
