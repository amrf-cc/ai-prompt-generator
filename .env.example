# OpenRouter — get a free key at https://openrouter.ai/keys (no credit card needed)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Auth.js (next-auth v5) — required when running with auth enabled
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth credentials — create a Web client at
# https://console.cloud.google.com/apis/credentials with redirect URIs:
#   http://localhost:3000/api/auth/callback/google
#   https://<your-fly-app>.fly.dev/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Locks down sign-in to one email domain. Leave blank to allow any Google account.
ALLOWED_EMAIL_DOMAIN=

# This user gets admin powers (edit Rules, edit locked brands, delete any
# history row). Leave blank to disable admin entirely.
ADMIN_EMAIL=

# Comma-separated brand slugs that non-admins cannot edit or delete.
LOCKED_BRAND_SLUGS=

# Required behind the Fly proxy (and any other reverse proxy) so Auth.js
# trusts the forwarded host header.
AUTH_TRUST_HOST=true

# Override these only if running outside the Docker container.
# Defaults are process.cwd()/data, /brands, /config, /uploads.
# DATA_DIR=
# BRANDS_DIR=
# CONFIG_DIR=
# UPLOADS_DIR=
